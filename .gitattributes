# Enforce consistent line endings across all environments
# Prevents phantom diffs from OneDrive, cross-platform, or editor differences

# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text file types
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.svg text eol=lf
*.env text eol=lf

# Declare binary file types (no line ending conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
